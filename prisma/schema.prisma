generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  ADMIN
  MANAGER
  STYLIST
  RECEPTIONIST
  CUSTOMER
}

enum EmployeeRole {
  ADMIN
  MANAGER
  STYLIST
  RECEPTIONIST
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL
  CANCELLED
}

//////////////////////
// ORGANIZATION
//////////////////////

model Organization {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  branches  Branch[]
  users     User[]
}

//////////////////////
// USER (Authentication)
//////////////////////

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  employee   Employee? @relation(fields: [employeeId], references: [id])
  employeeId String?   @unique

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?   @unique
}

//////////////////////
// BRANCH
//////////////////////

model Branch {
  id             String   @id @default(uuid())
  name           String
  address        String
  city           String
  state          String
  pincode        String
  phone          String?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String

  employees      Employee[]
  customers      Customer[]
  services       Service[]
  appointments   Appointment[]
  invoices       Invoice[]
  inventoryItems Inventory[]
  memberships    MembershipPlan[]
}

//////////////////////
// EMPLOYEE
//////////////////////

model Employee {
  id         String       @id @default(uuid())
  name       String
  email      String       @unique
  phone      String?
  role       EmployeeRole
  salary     Float?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())

  branch     Branch       @relation(fields: [branchId], references: [id])
  branchId   String

  servicesProvided Service[]
  appointmentServices AppointmentService[]
  paymentsHandled Payment[]
  user       User?
}

//////////////////////
// CUSTOMER
//////////////////////

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  gender    String?
  dob       DateTime?
  createdAt DateTime @default(now())

  branch    Branch   @relation(fields: [branchId], references: [id])
  branchId  String

  appointments Appointment[]
  invoices     Invoice[]
  memberships  CustomerMembership[]
  user         User?
}

//////////////////////
// SERVICE
//////////////////////

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  durationMin Int
  isActive    Boolean  @default(true)

  branch      Branch   @relation(fields: [branchId], references: [id])
  branchId    String

  providedBy  Employee? @relation(fields: [employeeId], references: [id])
  employeeId  String?

  appointmentServices AppointmentService[]
}

//////////////////////
// APPOINTMENT
//////////////////////

model Appointment {
  id          String            @id @default(uuid())
  date        DateTime
  status      AppointmentStatus @default(BOOKED)
  notes       String?
  createdAt   DateTime          @default(now())

  branch      Branch   @relation(fields: [branchId], references: [id])
  branchId    String

  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String

  services    AppointmentService[]
}

//////////////////////
// APPOINTMENT SERVICES (Many-to-Many with employee tracking)
//////////////////////

model AppointmentService {
  id            String   @id @default(uuid())
  priceAtTime   Float

  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId String

  service       Service @relation(fields: [serviceId], references: [id])
  serviceId     String

  employee      Employee @relation(fields: [employeeId], references: [id])
  employeeId    String
}

//////////////////////
// INVOICE
//////////////////////

model Invoice {
  id          String        @id @default(uuid())
  invoiceNo   String        @unique
  totalAmount Float
  taxAmount   Float
  discount    Float @default(0)
  finalAmount Float
  status      InvoiceStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  branch      Branch   @relation(fields: [branchId], references: [id])
  branchId    String

  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String

  payments    Payment[]
}

//////////////////////
// PAYMENT
//////////////////////

model Payment {
  id         String        @id @default(uuid())
  amount     Float
  method     PaymentMethod
  paidAt     DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId  String

  handledBy  Employee? @relation(fields: [employeeId], references: [id])
  employeeId String?
}

//////////////////////
// MEMBERSHIP PLAN
//////////////////////

model MembershipPlan {
  id          String   @id @default(uuid())
  name        String
  price       Float
  validityDays Int
  discountPercent Float

  branch      Branch   @relation(fields: [branchId], references: [id])
  branchId    String

  customers   CustomerMembership[]
}

model CustomerMembership {
  id             String   @id @default(uuid())
  startDate      DateTime @default(now())
  expiryDate     DateTime

  customer       Customer       @relation(fields: [customerId], references: [id])
  customerId     String

  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id])
  membershipPlanId String
}

//////////////////////
// INVENTORY
//////////////////////

model Inventory {
  id          String   @id @default(uuid())
  name        String
  quantity    Int
  unit        String
  costPrice   Float
  sellingPrice Float?
  lowStockAlert Int?

  branch      Branch   @relation(fields: [branchId], references: [id])
  branchId    String
}
